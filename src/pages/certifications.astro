---
import { Image } from "astro:assets";
import amdAgentsCert from "../assets/certs/amd-ai-agents-101-mcp.png";
import apiCert from "../assets/certs/borntodev-api-101.png";
import githubCert from "../assets/certs/borntodev-github-for-developer.png";
import Layout from "../layouts/Layout.astro";

type Certification = {
  title: string;
  issuer: string;
  issuerUrl?: string;
  issuedAt: Date;
  // Optional — not every issuer prints a short public credential ID on the cert
  // (AMD AI Academy ships PDFs with only a filename-hash reference, for example).
  credentialId?: string;
  thumbnail: ImageMetadata;
  fullImage: string;
};

const certifications: Certification[] = [
  {
    title: "AI Agents 101: Building AI Agents with MCP and Open-Source Inference",
    issuer: "AMD AI Academy",
    issuerUrl: "https://www.amd.com/en/corporate/university-program/ai-academy.html",
    issuedAt: new Date("2026-07-13"),
    credentialId: "4F5B2319BA414480BCA14CE8A98D1499166281",
    thumbnail: amdAgentsCert,
    fullImage: "/certs/amd-ai-agents-101-mcp.pdf"
  },
  {
    title: "API 101",
    issuer: "borntoDev School",
    issuerUrl: "https://school.borntodev.com/",
    issuedAt: new Date("2026-07-12"),
    credentialId: "yk7Y7QbFcF8B",
    thumbnail: apiCert,
    fullImage: "/certs/borntodev-api-101.png"
  },
  {
    title: "GitHub for Developer",
    issuer: "borntoDev School",
    issuerUrl: "https://school.borntodev.com/",
    issuedAt: new Date("2026-07-12"),
    credentialId: "TdpVu2Qy9aHU",
    thumbnail: githubCert,
    fullImage: "/certs/borntodev-github-for-developer.png"
  }
];

// Newest first — future-proofs the list as more certs land.
certifications.sort((a, b) => b.issuedAt.getTime() - a.issuedAt.getTime());

const fmtMonth = new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long" });
---

<Layout
  title="Certifications • pichxyaponn"
  description="Verified courses and certifications completed by Pichayapon Chaipanha."
>
  <main class="container mx-auto max-w-4xl p-2 pt-4">
    <section id="certifications" class="mb-8">
      <div class="rounded-lg border border-zinc-200 bg-white/80 p-5 shadow-sm backdrop-blur-sm">
        <h1 class="mb-1 text-lg font-medium text-zinc-900">Certifications</h1>
        <p class="mb-4 text-sm font-light text-zinc-600">
          Courses I've completed with a verified certificate. Click a thumbnail to view the full
          certificate.
        </p>
        <div class="space-y-3">
          {
            certifications.map((cert) => (
              <div class="fi gap-4 rounded-md border border-transparent p-3 transition-all duration-300 hover:border-zinc-200 hover:bg-zinc-100">
                <a
                  href={cert.fullImage}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block shrink-0"
                  aria-label={`View full certificate for ${cert.title}`}
                >
                  <Image
                    src={cert.thumbnail}
                    alt={`${cert.title} certificate from ${cert.issuer}`}
                    width={320}
                    layout="constrained"
                    class="w-28 rounded border border-zinc-200 sm:w-40"
                  />
                </a>
                <div class="flex-1 space-y-0.5">
                  <h3 class="text-bold">{cert.title}</h3>
                  <p class="text-sm text-zinc-500">
                    {cert.issuerUrl ? (
                      <a
                        href={cert.issuerUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="link"
                      >
                        {cert.issuer}
                      </a>
                    ) : (
                      cert.issuer
                    )}
                    {" · "}
                    <time datetime={cert.issuedAt.toISOString().slice(0, 10)}>
                      {fmtMonth.format(cert.issuedAt)}
                    </time>
                  </p>
                  {cert.credentialId && (
                    <p class="text-xs text-zinc-500">
                      Credential ID:{" "}
                      <code class="font-mono break-all text-zinc-700">{cert.credentialId}</code>
                    </p>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
