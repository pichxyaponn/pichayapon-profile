---
import { Image } from "astro:assets";
import me from "../assets/me.jpeg";
---

<section id="projects" class="mb-8">
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-5">
    <div class="md:col-span-2">
      <Image
        src={me}
        width={768}
        layout="constrained"
        alt="Pichayapon Chaipanha"
        class="h-full w-full rounded-lg border border-zinc-200 object-cover"
      />
    </div>
    <div class="md:col-span-3">
      <div
        class="space-y-1 rounded-lg border border-zinc-200 bg-white/80 p-3 shadow-sm backdrop-blur-sm transition-shadow duration-300 hover:shadow-lg"
      >
        <a
          href="http://xent-shop.xentinal.net/"
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-md border border-transparent p-3 py-2 transition-all duration-300 hover:border-zinc-200 hover:bg-zinc-100 hover:shadow-md"
        >
          <div class="fi justify-between">
            <div class="flex-1 space-y-0">
              <h3 class="text-bold">Digital Storefront</h3>
              <p class="text-sm text-zinc-500">
                Full-stack shop with wallet, tickets, and admin panel — product catalog, orders,
                PromptPay checkout, Tiptap-based content editor.
              </p>
              <div>
                <span class="tech-badge inline-block bg-sky-100 text-sky-800">Next.js</span>
                <span class="tech-badge inline-block bg-emerald-100 text-emerald-800"
                  >ElysiaJS</span
                >
                <span class="tech-badge inline-block bg-neutral-100 text-neutral-800"
                  >Drizzle</span
                >
                <span class="tech-badge inline-block bg-amber-100 text-amber-800"
                  >better-auth</span
                >
              </div>
            </div>
            <div class="text-sm whitespace-nowrap text-zinc-500">2025 · Personal</div>
          </div>
        </a>
        <a
          href="https://nisit-savings.pichayapon.com"
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-md border border-transparent p-3 py-2 transition-all duration-300 hover:border-zinc-200 hover:bg-zinc-100 hover:shadow-md"
        >
          <div class="fi justify-between">
            <div class="flex-1 space-y-0">
              <h3 class="text-bold">Student Group Savings</h3>
              <p class="text-sm text-zinc-500">
                Payment collection app for a university student group — PromptPay QR, bank-API
                slip verification, admin panel with soft-void audit trail. ~200 students in
                production.
              </p>
              <div>
                <span class="tech-badge inline-block bg-sky-100 text-sky-800">Next.js</span>
                <span class="tech-badge inline-block bg-emerald-100 text-emerald-800"
                  >ElysiaJS</span
                >
                <span class="tech-badge inline-block bg-neutral-100 text-neutral-800"
                  >Drizzle</span
                >
                <span class="tech-badge inline-block bg-indigo-100 text-indigo-800">Postgres</span
                >
              </div>
            </div>
            <div class="text-sm whitespace-nowrap text-zinc-500">2026 · Personal</div>
          </div>
        </a>
        <div
          class="block rounded-md border border-transparent p-3 py-2 transition-all duration-300"
        >
          <div class="fi justify-between">
            <div class="flex-1 space-y-0">
              <h3 class="text-bold">Personal Dev Toolkit — LLMs &amp; Agents</h3>
              <p class="text-sm text-zinc-500">
                A growing set of Claude Code skills and MCP servers wired around my day-to-day dev
                and ops loop — repo audits, code review, Obsidian vault reads, SSH deploys.
              </p>
              <div>
                <span class="tech-badge inline-block bg-violet-100 text-violet-800"
                  >Claude Code</span
                >
                <span class="tech-badge inline-block bg-rose-100 text-rose-800">MCP</span>
                <span class="tech-badge inline-block bg-sky-100 text-sky-800">TypeScript</span>
              </div>
            </div>
            <div class="text-sm whitespace-nowrap text-zinc-500">2025 → now</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
